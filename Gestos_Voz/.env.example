MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/SistemaTotems
# Alternativa aceptada por lib/mongodb.ts:
# MONGODB_URI=...

# Local: obligatorio para URLs de imágenes/videos en respuestas API.
# Vercel: opcional (si no se define, se usa https://VERCEL_URL automáticamente).
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Opcional: fijar un tótem sin pantalla de login (despliegue en fábrica).
# En uso normal cada equipo inicia sesión con usuario/contraseña del panel admin.
# NEXT_PUBLIC_TOTEM_ID=
